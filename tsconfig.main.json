{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "suppressImplicitAnyIndexErrors": true
  },
  "include": ["src/main/**/*", "src/types.ts", "src/uuid.d.ts"],
  "exclude": ["node_modules", "src/renderer"]
}
